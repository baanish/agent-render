    "@codemirror/search": "^6.5.10",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.2",
    "@git-diff-view/file": "^0.1.1",
    "@git-diff-view/react": "^0.1.1",
    "@tanstack/react-table": "^8.21.3",
